<div class="row">
  <div class="col-6 offset-3">
    <div class="card shadow">
      <div class="card-body p-4">
        <%= form_with model: integration_fillea, local: true do |f| %>
          <% if integration_fillea.errors.any? %>
            <div class="alert alert-danger">
              <ul class="mb-0">
                <% integration_fillea.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <div class="input-group mb-3 shadow-sm">
            <span class="<%= form_input_group_class %>">
              <i class="bi bi-geo-alt me-1"></i>
              <%= f.label :zoning_id, "Azzonamento" %>
            </span>
            <%= f.collection_select :zoning_id, @zonings, :id, :descrizione_azzonamento, { prompt: "Seleziona un azzonamento" }, class: "form-select" %>
          </div>
          <div class="input-group mb-3 shadow-sm">
            <span class="<%= form_input_group_class %>">
              <i class="bi bi-calendar-event me-1"></i>
              <%= f.label :year, "Anno" %>
            </span>
            <%= f.text_field :year, class: "form-control" %>
          </div>
          <div class="input-group mb-4 shadow-sm">
            <span class="<%= form_input_group_class %>">
              <i class="bi bi-people-fill me-1"></i>
              <%= f.label :subscribers_ce, "Iscritti Cassa Edile" %>
            </span>
            <%= f.number_field :subscribers_ce, class: "form-control" %>
          </div>
          <hr class="text-dark"/>
          <div class="d-flex justify-content-end mt-4">
            <%= link_to integration_filleas_path, class: "btn btn-dark shadow me-3" do %>
              <i class="bi bi-arrow-counterclockwise me-2"></i>
              Annulla
            <% end %>
            <%= f.button class: form_button_class do %>
              <i class="bi bi-arrow-left-right me-1"></i>&emsp;<%= form_submit_label_integration_fillea %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
