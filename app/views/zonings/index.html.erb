<% content_for :title, "Azzonamenti" %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h4 mb-0">Azzonamenti</h1>
  <%= link_to "Nuovo azzonamento", new_zoning_path, class: "btn btn-primary" %>
</div>

<% if @zonings.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Codice</th>
          <th>Descrizione</th>
          <th class="text-end">Azioni</th>
        </tr>
      </thead>
      <tbody>
        <% @zonings.each do |zoning| %>
          <tr>
            <td><%= zoning.codice_azzonamento %></td>
            <td><%= zoning.descrizione_azzonamento %></td>
            <td class="text-end">
              <%= link_to "Modifica", edit_zoning_path(zoning), class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "Elimina", confirm_destroy_zoning_path(zoning), class: "btn btn-sm btn-outline-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">Nessun azzonamento inserito.</p>
<% end %>
