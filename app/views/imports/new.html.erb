<% content_for :title, "Importazioni" %>
<h1 class="h4 mb-4">Importazioni</h1>
<div class="card shadow-sm">
  <div class="card-body p-4">
    <%= form_with model: @import_form, scope: :import_form, url: imports_path, local: true, multipart: true do |f| %>
      <% if @import_form.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @import_form.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <% if @conflict %>
        <%= f.hidden_field :stored_path %>
        <%= f.hidden_field :zoning_id %>
        <%= f.hidden_field :anno %>
        <%= f.hidden_field :mese %>
        <div class="alert alert-warning">
          Esiste già un'importazione per l'azzonamento <strong><%= @import_form.zoning&.descrizione_azzonamento %></strong>,
          <strong><%= @import_form.mese %> <%= @import_form.anno %></strong>.
          Vuoi mantenere i dati esistenti o sovrascriverli con il nuovo file?
        </div>
        <div class="d-flex gap-2">
          <%= f.submit "Mantieni i dati esistenti", name: "import_form[resolution]", value: "keep",
            class: "btn btn-outline-secondary" %>
          <%= f.submit "Sovrascrivi", name: "import_form[resolution]", value: "overwrite", class: "btn btn-danger" %>
        </div>
      <% else %>
        <div class="mb-3">
          <%= f.label :file, "File CSV", class: "form-label" %>
          <%= f.file_field :file, class: "form-control", accept: ".csv" %>
        </div>
        <div class="mb-3">
          <%= f.label :zoning_id, "Azzonamento", class: "form-label" %>
          <%= f.collection_select :zoning_id, @zonings, :id, :descrizione_azzonamento,
            { prompt: "Seleziona un azzonamento" }, class: "form-select" %>
        </div>
        <div class="mb-3">
          <%= f.label :anno, "Anno di riferimento", class: "form-label" %>
          <%= f.text_field :anno, class: "form-control", placeholder: "es. 2026" %>
        </div>
        <div class="mb-3">
          <%= f.label :mese, "Mese di riferimento", class: "form-label" %>
          <%= f.select :mese, ImportForm::MESI, { prompt: "Seleziona un mese" }, class: "form-select" %>
        </div>
        <div class="d-grid">
          <%= f.submit "Importa", class: "btn btn-primary" %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
